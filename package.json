{
  "name": "zenith-ride",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "test:e2e": "playwright test",
    "kaze": "node kaze-agent/start.js",
    "kaze:voice": "python kaze_voice_server.py",
    "dev:all": "npx -y concurrently -n vite,kaze,voice -c green,cyan,magenta \"npm run dev\" \"npm run kaze\" \"python kaze_voice_server.py\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.39.0",
    "agora-rtc-sdk-ng": "^4.20.0",
    "h3-js": "^4.4.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.383.0",
    "mapbox-gl": "^3.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@playwright/test": "^1.59.1",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.1.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "playwright": "^1.59.1",
    "postcss": "^8.4.31",
    "qrcode-terminal": "^0.12.0",
    "supabase": "^2.95.6",
    "tailwindcss": "^3.3.5",
    "typescript": "^6.0.0",
    "vite": "^5.4.0"
  }
}
