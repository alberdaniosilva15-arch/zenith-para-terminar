# .env.example — template seguro para commitar
# Copia este ficheiro para .env e preenche com as tuas chaves reais
# NUNCA commitar o ficheiro .env com chaves reais!
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXX
VITE_MAPBOX_TOKEN=pk.XXXX
VITE_AGORA_APP_ID=XXXX
VITE_GOOGLE_MAPS_KEY=GOOGLE_MAPS_BROWSER_KEY_HERE
# GEMINI_API_KEY NÃO VAI AQUI — vai como secret da Edge Function:
# npx supabase secrets set GEMINI_API_KEY="TUA_CHAVE"

# Hermes local (opcional para auto-start do Kaze Core)
HERMES_PORT=4000
# HERMES_COMMAND="caminho ou comando completo para arrancar o Hermes"
# HERMES_ENTRY="C:\\caminho\\para\\start.js"
# HERMES_DIR="C:\\caminho\\para\\a\\pasta\\do\\Hermes"
# HERMES_REPO="C:\\Users\\Ariane Marcelino\\Videos\\hermes-agent-main\\hermes-agent-main"
# HERMES_PYTHON="C:\\Users\\Ariane Marcelino\\Videos\\hermes-agent-main\\hermes-agent-main\\venv\\Scripts\\python.exe"
# HERMES_MODEL="gemini-2.5-flash"

# Vigilante Engine (IA Admin) — activar APENAS em produção com monitorização de custos
# false = desactivado — protege quota gratuita Gemini (usar no MVP)
# true = activo — corre a cada 2min para cada admin logado (pode gerar custos)
VITE_VIGILANTE_ENABLED=false
