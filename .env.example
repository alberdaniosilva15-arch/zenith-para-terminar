# =============================================================================
# MOTOGO AI v3.0 — Variáveis de Ambiente
# Copia para .env e preenche com os teus valores reais
# NUNCA faças commit do ficheiro .env
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhb...chave_anon_publica

# ── Mapbox (para mapa 3D de Luanda) ──────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1...token_mapbox

# ── Agora.io (VoIP — guardar nos Secrets do Supabase, NÃO aqui) ──────────────
# Estes valores vão para Supabase Dashboard → Settings → Edge Functions → Secrets
# AGORA_APP_ID=seu_app_id
# AGORA_APP_CERT=seu_app_certificate
#
# Apenas o App ID é seguro no frontend — o App Certificate NUNCA deve sair do servidor

# ── Edge Functions — CORS ────────────────────────────────────────────────────
# Em produção: define o teu domínio exacto (sem trailing slash)
# Exemplo: https://zenithride.ao
# Em desenvolvimento: deixa vazio (usa '*' como default)
ALLOWED_ORIGIN=
